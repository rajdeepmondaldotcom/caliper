# Local PyPI publish credentials for scripts/publish.sh.
#
# Copy to .env (git-ignored) and replace the placeholders. The token
# lives only on your machine. Never commit .env, never paste the
# value into a chat.
#
# Get a token at https://pypi.org/manage/account/token/ scoped to
# the caliper-ai project. Twine reads username and password directly
# from the environment.
#
# GitHub Actions uses the `PYPI_API_TOKEN` secret on the `pypi`
# deployment environment. This file is only for the local
# `scripts/publish.sh` path documented in
# docs/release-and-ux-overhaul/RUNBOOK-publish.md.

TWINE_USERNAME=__token__
TWINE_PASSWORD=pypi-replace-me

# Optional alias. Some local tooling reads PYPI_API_TOKEN instead.
PYPI_API_TOKEN=pypi-replace-me
