{
  "name": "caliper-statusbar",
  "displayName": "Caliper Statusbar",
  "description": "Show local Caliper AI coding spend in the VS Code status bar.",
  "version": "0.0.2",
  "publisher": "rajdeepmondaldotcom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajdeepmondaldotcom/caliper"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "caliper.openReceipt",
        "title": "Caliper: Open Receipt"
      }
    ],
    "configuration": {
      "title": "Caliper",
      "properties": {
        "caliper.command": {
          "type": "string",
          "default": "caliper",
          "description": "Caliper executable to run."
        },
        "caliper.refreshSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "Statusbar refresh interval."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/vscode": "1.118.0",
    "@vscode/vsce": "3.9.1",
    "typescript": "6.0.3"
  }
}
